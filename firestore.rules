rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Only admins or cloud functions can delete users
    }

    // User scores (Quizzes and IQ)
    match /userScores/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Feedback collection - anyone logged in can create, nobody can read/edit
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Analytics - write only
    match /analytics/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
